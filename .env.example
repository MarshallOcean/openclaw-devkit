# ==============================================================================
# OpenClaw 环境配置模板 (.env.example)
# ==============================================================================
# 使用方法: cp .env.example .env 并根据需要修改配置

# ─────────────────────────────────────────────────────────────────
# 基础路径配置 (容器化最佳实践：配置种子与状态分离)
# ─────────────────────────────────────────────────────────────────
# 宿主机配置存储路径 (默认: ~/.openclaw，作为初始化种子挂载)
OPENCLAW_CONFIG_DIR=~/.openclaw

# 宿主机工作区路径 (默认: ~/.openclaw/workspace，读写挂载)
OPENCLAW_WORKSPACE_DIR=~/.openclaw/workspace

# 注意：会话和身份数据持久化在 "openclaw-state" 命名卷中，不再直接受宿主机目录覆盖影响。

# ─────────────────────────────────────────────────────────────────
# 网络服务配置
# ─────────────────────────────────────────────────────────────────
# Gateway 访问端口
OPENCLAW_GATEWAY_PORT=18789

# Bridge 访问端口
OPENCLAW_BRIDGE_PORT=18790

# Gateway 绑定模式 (lan 或 local)
OPENCLAW_GATEWAY_BIND=lan

# Gateway 访问 Token (留空则安装时自动生成)
OPENCLAW_GATEWAY_TOKEN=

# ─────────────────────────────────────────────────────────────────
# 代理与镜像配置
# ─────────────────────────────────────────────────────────────────
# 💡 建议在宿主机 hosts 文件中添加 "127.0.0.1 host.docker.internal" 映射
# 这样可以让本地直连、容器内开发共用同一套代理配置字符串，提升环境一致性。
# 容器访问外网用的代理 (示例: http://host.docker.internal:7897)
HTTP_PROXY=
HTTPS_PROXY=

# 镜像名称
# - openclaw:dev       (默认) 标准开发版 (Node + Go + Python + Playwright)
# - openclaw:dev-java  Java 增强版 (在标准版基础上集成 JDK 25 + Gradle + Maven)
OPENCLAW_IMAGE=openclaw:dev

# GitHub Token (用于 make update 访问 GitHub API)
GITHUB_TOKEN=your_github_token_here

# ─────────────────────────────────────────────────────────────────
# 高级挂载配置
# ─────────────────────────────────────────────────────────────────
# 额外挂载点 (格式: src:dst[:ro],src2:dst2)
OPENCLAW_EXTRA_MOUNTS=

# 命名卷名称 (可选, 用于持久化整个 home)
OPENCLAW_HOME_VOLUME=
